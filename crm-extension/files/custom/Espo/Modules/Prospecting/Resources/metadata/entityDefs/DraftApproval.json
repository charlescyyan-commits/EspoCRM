{
  "fields": {
    "name": {"type": "varchar", "maxLength": 255, "required": true, "trim": true},
    "draftId": {"type": "varchar", "maxLength": 255, "required": true, "trim": true},
    "status": {"type": "enum", "required": true, "options": ["PENDING", "APPROVED", "REJECTED"], "default": "PENDING", "displayAsLabel": true, "style": {"PENDING": "warning", "APPROVED": "success", "REJECTED": "danger"}},
    "approvedAt": {"type": "datetime", "required": false, "notNull": false},
    "decisionReason": {"type": "text", "required": false, "notNull": false},
    "evidenceReference": {"type": "varchar", "maxLength": 255, "required": false, "notNull": false, "trim": true},
    "scoreSnapshot": {"type": "varchar", "maxLength": 255, "required": false, "notNull": false, "trim": true},
    "contentHash": {"type": "varchar", "maxLength": 64, "required": false, "notNull": false, "trim": true},
    "lead": {"type": "link", "required": true},
    "approvedBy": {"type": "link", "required": false, "notNull": false},
    "createdAt": {"type": "datetime", "readOnly": true},
    "modifiedAt": {"type": "datetime", "readOnly": true},
    "createdBy": {"type": "link", "readOnly": true},
    "modifiedBy": {"type": "link", "readOnly": true},
    "assignedUser": {"type": "link"},
    "teams": {"type": "linkMultiple"}
  },
  "links": {
    "lead": {"type": "belongsTo", "entity": "Lead", "foreign": "draftApprovals"},
    "approvedBy": {"type": "belongsTo", "entity": "User"},
    "createdBy": {"type": "belongsTo", "entity": "User"},
    "modifiedBy": {"type": "belongsTo", "entity": "User"},
    "assignedUser": {"type": "belongsTo", "entity": "User"},
    "teams": {"type": "hasMany", "entity": "Team", "relationName": "entityTeam", "layoutRelationshipsDisabled": true},
    "sendExecutions": {"type": "hasMany", "entity": "SendExecution", "foreign": "draftApproval"}
  },
  "collection": {"orderBy": "modifiedAt", "order": "desc", "textFilterFields": ["name", "draftId", "status", "evidenceReference", "scoreSnapshot"]},
  "deleteId": true,
  "indexes": {
    "draftId": {"type": "unique", "columns": ["draftId", "deleteId"]},
    "leadId": {"columns": ["leadId"]}
  }
}
