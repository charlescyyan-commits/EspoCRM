      "default": "NEW",
      "displayAsLabel": true,
      "style": {
        "NEW": "default",
        "RESEARCHING": "warning",
        "RESEARCH_COMPLETED": "info",
        "QUALIFIED": "primary",
        "CONTACT_READY": "success",
        "CONTACTED": "primary",
