  "links": {
    "researchEvidences": {
      "type": "hasMany",
      "entity": "ResearchEvidence",
      "foreign": "lead"
    },
    "salesFeedbacks": {
      "type": "hasMany",
      "entity": "SalesFeedback",
      "foreign": "lead"
    },
    "learningSignals": {
      "type": "hasMany",
      "entity": "LearningSignal",
      "foreign": "lead"
    },
    "emailEvents": {
      "type": "hasMany",
      "entity": "EmailEvent",
      "foreign": "lead"
    },
    "draftApprovals": {
      "type": "hasMany",
      "entity": "DraftApproval",
      "foreign": "lead"
    },
    "sendExecutions": {
      "type": "hasMany",
      "entity": "SendExecution",
      "foreign": "lead"
    },
    "replyEvents": {
      "type": "hasMany",
      "entity": "ReplyEvent",
      "foreign": "lead"
    }
  },
  "indexes": {
    "peSourceBatchId": {
      "columns": ["peSourceBatchId"]
    }
  },
  "formula": "if (entity\\isAttributeChanged('peResearchStatus') && peResearchStatus == 'COMPLETED') {\n    outreachStatus = 'RESEARCH_COMPLETED';\n}\nif (entity\\isAttributeChanged('peOpportunityScoreV4') && peOpportunityScoreV4 >= 80) {\n    pePriorityLevel = 'HIGH';\n}\nif ((entity\\isAttributeChanged('emailAddress') && emailAddress != '') || (entity\\isAttributeChanged('phoneNumber') && phoneNumber != '')) {\n    if (outreachStatus == 'RESEARCH_COMPLETED' || outreachStatus == 'QUALIFIED') {\n        outreachStatus = 'CONTACT_READY';\n    }\n}"
}
