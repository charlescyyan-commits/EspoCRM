      "notNull": false,
      "options": ["New", "Reviewed", "Contacted", "Interested", "Qualified", "Converted", "Rejected"],
      "default": "New",
      "displayAsLabel": true,
      "style": {
        "New": "default",
        "Reviewed": "info",
        "Contacted": "primary",
        "Interested": "success",
        "Qualified": "success",
        "Converted": "success",
        "Rejected": "danger"
      },
      "tooltip": true
