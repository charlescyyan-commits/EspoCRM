      "default": "NONE",
      "displayAsLabel": true,
      "style": {
        "NONE": "default",
        "DRAFT_READY": "warning",
        "DRAFT_PENDING_APPROVAL": "warning",
        "APPROVED": "info",
        "REJECTED": "danger",
        "PENDING": "warning",
        "READY_TO_SEND": "info",
