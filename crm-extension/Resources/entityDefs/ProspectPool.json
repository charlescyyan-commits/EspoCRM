{
  "fields": {
    "name": {"type": "varchar", "maxLength": 255, "required": true, "trim": true},
    "externalProspectId": {"type": "varchar", "maxLength": 128, "required": false, "notNull": false, "trim": true},
    "source": {"type": "varchar", "maxLength": 100, "required": false, "notNull": false, "trim": true},
    "sourceUrl": {"type": "url", "required": false, "notNull": false},
    "website": {"type": "url", "required": false, "notNull": false},
    "country": {"type": "varchar", "maxLength": 100, "required": false, "notNull": false, "trim": true},
    "queue": {"type": "enum", "required": true, "options": ["DISCOVERY", "QUALIFICATION", "RESEARCH", "CRM"], "default": "DISCOVERY", "displayAsLabel": true},
    "status": {"type": "enum", "required": true, "options": ["WAITING", "RUNNING", "COMPLETED", "FAILED"], "default": "WAITING", "displayAsLabel": true},
    "researchStatus": {"type": "enum", "required": true, "options": ["NOT_STARTED", "PENDING", "COMPLETED", "FAILED"], "default": "NOT_STARTED", "displayAsLabel": true},
    "qualificationStatus": {"type": "enum", "required": true, "options": ["PENDING", "QUALIFIED", "REJECTED"], "default": "PENDING", "displayAsLabel": true},
    "crmPushStatus": {"type": "enum", "required": true, "options": ["NOT_READY", "READY", "PUSHED", "FAILED"], "default": "NOT_READY", "displayAsLabel": true},
    "qualifiedAt": {"type": "datetime", "required": false, "notNull": false},
    "crmPushedAt": {"type": "datetime", "required": false, "notNull": false},
    "note": {"type": "text", "required": false, "notNull": false},
    "searchJob": {"type": "link"},
    "createdAt": {"type": "datetime", "readOnly": true},
    "assignedUser": {"type": "link"},
    "teams": {"type": "linkMultiple"}
  },
  "links": {
    "searchJob": {"type": "belongsTo", "entity": "SearchJob", "foreign": "prospectPools"},
    "assignedUser": {"type": "belongsTo", "entity": "User"},
    "teams": {"type": "hasMany", "entity": "Team", "relationName": "entityTeam", "layoutRelationshipsDisabled": true}
  },
  "collection": {"orderBy": "createdAt", "order": "desc", "textFilterFields": ["name", "externalProspectId", "source", "country", "website"]},
  "indexes": {"externalProspectId": {"columns": ["externalProspectId"]}, "queue": {"columns": ["queue"]}, "status": {"columns": ["status"]}}
}
