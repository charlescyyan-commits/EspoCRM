{
  "fields": {
    "name": {"type": "varchar", "maxLength": 255, "required": true, "trim": true},
    "quantity": {"type": "float", "required": true, "default": 1, "min": 0},
    "unitPrice": {"type": "currency", "required": true, "default": 0},
    "amount": {"type": "currency", "required": false, "notNull": false},
    "quote": {"type": "link", "required": true},
    "createdAt": {"type": "datetime", "readOnly": true},
    "modifiedAt": {"type": "datetime", "readOnly": true}
  },
  "links": {
    "quote": {"type": "belongsTo", "entity": "Quote", "foreign": "quoteItems"}
  },
  "collection": {"orderBy": "createdAt", "order": "asc", "textFilterFields": ["name"]},
  "deleteId": true,
  "indexes": {
    "quoteId": {"columns": ["quoteId"]}
  }
}
